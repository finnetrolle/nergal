# Telegram Bot Configuration
# Get your token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Response Style Configuration
# Supported styles: default
# - default: Neutral, helpful assistant
STYLE=default

# LLM Provider Configuration
# Supported providers: zai, openai, anthropic, minimax
LLM_PROVIDER=zai
LLM_API_KEY=your_llm_api_key_here
# Model name (use UPPERCASE for Z.ai Coding Plan: GLM-4-flash, GLM-4.7, GLM-5)
LLM_MODEL=GLM-4-flash
# Optional: Custom API endpoint (leave empty for default)
# LLM_BASE_URL=
LLM_TEMPERATURE=0.7
# Optional: Maximum tokens to generate (leave empty for no limit)
# LLM_MAX_TOKENS=
# Request timeout in seconds (increase for complex queries with web search)
LLM_TIMEOUT=120.0

# Web Search Configuration
# Enable web search to allow the bot to search the internet
WEB_SEARCH_ENABLED=false
# API key for web search (defaults to LLM_API_KEY if not set)
# WEB_SEARCH_API_KEY=
# MCP endpoint URL for web search
WEB_SEARCH_MCP_URL=https://api.z.ai/api/mcp/web_search_prime/mcp
# Maximum number of search results to return (1-50)
WEB_SEARCH_MAX_RESULTS=5
# Request timeout for web search in seconds
WEB_SEARCH_TIMEOUT=30.0

# Speech-to-Text (Voice Message) Configuration
# Enable voice message processing with local Whisper
STT_ENABLED=true
# STT provider: local (faster-whisper) or openai (requires API key)
STT_PROVIDER=local
# Whisper model size: tiny, base, small, medium, large-v3
# - tiny: fastest, lowest quality (~1GB RAM)
# - base: good balance of speed and quality (~1GB RAM) [recommended for CPU]
# - small: better quality, slower (~2GB RAM)
# - medium: high quality, much slower (~5GB RAM)
# - large-v3: best quality, slowest (~10GB RAM)
STT_MODEL=base
# Language for transcription (ISO 639-1 code)
STT_LANGUAGE=ru
# Maximum voice message duration in seconds (60 = 1 minute)
STT_MAX_DURATION_SECONDS=60
# Device for Whisper: cpu or cuda (if GPU available)
STT_DEVICE=cpu
# Compute type: int8 (for CPU), float16 (for GPU), float32
STT_COMPUTE_TYPE=int8

# Group Chat Configuration
# Enable bot to work in group chats
GROUP_CHAT_ENABLED=true
# Bot name to detect mentions in messages (case-insensitive)
GROUP_CHAT_BOT_NAME=Sil
# Bot Telegram username (without @) for mention detection
# Leave empty to auto-detect from bot API
# GROUP_CHAT_BOT_USERNAME=your_bot_username
# Respond when someone replies to bot's message
GROUP_CHAT_RESPOND_TO_REPLIES=true
# Respond when bot name or username is mentioned in message
GROUP_CHAT_RESPOND_TO_MENTIONS=true
#
# IMPORTANT: For name-based mentions (e.g., "Sil, hello!") to work,
# you must DISABLE Privacy Mode in @BotFather:
# 1. Open @BotFather
# 2. Send /mybots and select your bot
# 3. Go to Bot Settings -> Group Privacy -> Disable

# Agent Configuration
# Enable/disable specific specialized agents
# Web Search Agent - search the web for information (requires WEB_SEARCH_ENABLED=true)
AGENTS_WEB_SEARCH_ENABLED=true
# News Agent - aggregate and process news from multiple sources
AGENTS_NEWS_ENABLED=true
# Analysis Agent - analyze and synthesize information
AGENTS_ANALYSIS_ENABLED=true
# Fact Check Agent - verify facts and claims
AGENTS_FACT_CHECK_ENABLED=true
# Comparison Agent - compare alternatives
AGENTS_COMPARISON_ENABLED=true
# Summary Agent - summarize and condense information
AGENTS_SUMMARY_ENABLED=true
# Code Analysis Agent - analyze code and repositories
AGENTS_CODE_ANALYSIS_ENABLED=true
# Metrics Agent - retrieve metrics and statistics
AGENTS_METRICS_ENABLED=true
# Expertise Agent - domain-specific expertise
AGENTS_EXPERTISE_ENABLED=true
# Tech Docs Agent - search technical documentation
AGENTS_TECH_DOCS_ENABLED=true
AGENTS_TODOIST_ENABLED=true
